<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="selected"
            type="Boolean" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginVertical="5dp"
        android:background="@drawable/bg_for_purchase_item"
        android:backgroundTint="@{selected?@color/color_theme_purple_light:@color/color_text_tertiary}"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:paddingVertical="10dp"
        tools:background="@color/color_theme_blue">



        <TextView
            android:id="@+id/tv_name"
            style="@style/TextViewLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_medium"
            android:gravity="start"
            android:maxLines="1"
            android:textColor="@{selected?@color/color_text_primary:@color/color_text_tertiary}"
            android:textSize="@dimen/ts_16"
            tools:text="Arabic" />

        <TextView
            android:id="@+id/tv_name_eng"
            style="@style/TextViewLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="start"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@{selected?@color/color_text_primary:@color/color_text_tertiary}"
            android:maxLines="1"
            android:textSize="@dimen/ts_14"
            tools:text="Arabic"

            />


    </LinearLayout>
</layout>